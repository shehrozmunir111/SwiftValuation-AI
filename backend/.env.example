# --- App ---
APP_NAME=AutoFlow Valuation Engine
DEBUG=false
SECRET_KEY=change-me

# Turn on for demos (disables paid integrations selectively)
MOCK_MODE=true
ZOHO_MOCK_MODE=true

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/autoflow_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379

# --- Anthropic Claude (AI classification + vision) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# --- VIN Decoder API ---
VIN_DECODER_API_KEY=
VIN_DECODER_URL=

# --- Zoho CRM ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_BASE_URL=https://www.zohoapis.com/crm/v2
ZOHO_CARS_MODULE=Cars

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=autoflow-photos

# --- CORS ---
ALLOWED_ORIGINS=["http://localhost:3000"]

